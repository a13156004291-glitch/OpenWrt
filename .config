# 目标架构 (保命核心，别动它)
CONFIG_TARGET_ipq807x=y
CONFIG_TARGET_ipq807x_generic=y
CONFIG_TARGET_ipq807x_generic_DEVICE_xiaomi_ax3600-stock=y

# 1. 界面与 iStore 商店 (你要的卡片首页)
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-i18n-quickstart-zh-cn=y
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-i18n-store-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# 2. 科学上网终极方案 (直接缝死在系统里，告别依赖报错)
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-openclash=y

# 3. 家用基础核心必备 (正常使用的关键)
# UPnP (打游戏、BT下载必备，自动端口映射，不装你的游戏主机连网会严格受限)
CONFIG_PACKAGE_luci-app-upnp=y
# Turbo ACC 网络加速 (高通芯片必装，开启硬件直通加速和BBR，极大降低延迟)
CONFIG_PACKAGE_luci-app-turboacc=y
# TTYD 网页终端 (极度实用，以后直接在网页里敲命令，再也不用开黑框 SSH 软件)
CONFIG_PACKAGE_luci-app-ttyd=y
